# ============================================================
# ClassScan — Environment Variables Template
# ============================================================
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
#   cp .env.example .env.local
#
# ห้าม commit .env.local ลง Git (ดู .gitignore)
# ============================================================

# ------------------------------------------------------------
# SUPABASE — Web App (Client-side)
# ดูค่าได้ที่: Supabase Dashboard > Project Settings > API
# ------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# SUPABASE — Edge Functions & CLI (Server-side เท่านั้น)
# ห้ามใส่ค่าเหล่านี้ใน client JS เด็ดขาด
# ดูค่าได้ที่: Supabase Dashboard > Project Settings > API
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# SUPABASE CLI — สำหรับ deploy Edge Functions ผ่าน CLI / CI
# ดูค่าได้ที่: https://supabase.com/dashboard/account/tokens
# ------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# LINE Messaging API — Edge Functions เท่านั้น
# ดูค่าได้ที่: LINE Developers Console > Channel > Messaging API
# ------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx...
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
